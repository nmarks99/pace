record(ao, "ezec:test:ao") {
    field(VAL, 3.14)
    field(PREC, 2)
}

record(longout, "ezec:test:longout") {
    field(VAL, 42)
}

record(stringout, "ezec:test:stringout") {
    field(VAL, "Hello World")
}

record(mbbo, "ezec:test:mbbo") {
    field(ZRVL, 0)
    field(ONVL, 1)
    field(TWVL, 2)
    field(ZRST, "Zero")
    field(ONST, "One")
    field(TWST, "Two")
}

record(waveform, "ezec:test:wfchar") {
    field(FTVL, "CHAR")
    field(INP, "{const: [1,2,3]}")
    field(NELM, 3)
}

record(waveform, "ezec:test:wfdouble") {
    field(FTVL, "DOUBLE")
    field(INP, "{const: [1.11,2.22,3.33]}")
    field(NELM, 3)
}
